{
  "manifest_version": 3,
  "name": "Maira WA Bridge",
  "version": "0.1.0",
  "description": "Reply-only WhatsApp Web bridge for Maira Sales. Polls the app outbox and sends paced AI bubbles; forwards inbound messages to the app. Same gateway contract as the WAHA/VPS path.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Maira WA Bridge" },
  "options_page": "options.html"
}
