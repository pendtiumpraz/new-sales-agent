{
  "manifest_version": 3,
  "name": "Maira WA + Discovery Bridge",
  "version": "0.2.0",
  "description": "One modular bridge for Maira Sales: reply-only WhatsApp Web gateway (paced AI bubbles) + LinkedIn/Instagram lead discovery (extract profiles behind login → /api/ingest).",
  "permissions": ["storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://*.linkedin.com/*",
    "https://*.instagram.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.linkedin.com/in/*", "https://*.instagram.com/*"],
      "js": ["discovery.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Maira WA + Discovery Bridge" },
  "options_page": "options.html"
}
