{
  "manifest_version": 3,
  "name": "Maira WA + Discovery Bridge",
  "version": "0.3.0",
  "description": "Multi-platform bridge untuk Maira Sales: WhatsApp Web gateway + Discovery dari LinkedIn, Instagram, Facebook, TikTok, Shopee, Google Search.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://*.linkedin.com/*",
    "https://*.instagram.com/*",
    "https://*.facebook.com/*",
    "https://*.tiktok.com/*",
    "https://*.shopee.co.id/*",
    "https://www.google.com/search?*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.linkedin.com/in/*",
        "https://*.linkedin.com/company/*",
        "https://*.linkedin.com/posts/*",
        "https://*.linkedin.com/feed/update/*",
        "https://*.instagram.com/*",
        "https://*.facebook.com/*",
        "https://*.tiktok.com/@*",
        "https://*.shopee.co.id/*",
        "https://*.tokopedia.com/*",
        "https://www.google.com/search?*",
        "https://www.google.com/maps/*",
        "https://maps.google.com/*"
      ],
      "js": ["discovery.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Maira WA + Discovery" },
  "options_page": "options.html"
}
