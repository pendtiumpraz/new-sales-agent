# Copy to .env (gitignored) and fill in. Used by docker-compose.yml + bridge.mjs.

# Where Maira runs. For local dev with `npm run dev` on :3100, from inside the
# bridge container use host.docker.internal; deployed, use the public URL.
APP_URL=http://host.docker.internal:3100

# Shared secret — MUST equal the app's WA_GATEWAY_TOKEN (.env.local).
WA_GATEWAY_TOKEN=testtoken123

# Our session this WAHA number is bound to (rep:<userId> or platform:<tenantId>).
# Must exist + be "connected" in wa_session (see scripts/seed-wa-session.ts).
SESSION_ID=rep:u_rep

# WAHA's own session name (the dashboard default is "default").
WAHA_SESSION=default

# Optional: set if you enabled WHATSAPP_API_KEY on WAHA.
WAHA_API_KEY=

# Poll cadence for the outbox.
POLL_MS=3000
