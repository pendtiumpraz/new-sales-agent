# Vercel AI Gateway (gives access to Deepseek + 100+ models via one key).
# Pull this automatically with `vercel env pull .env.local` after `vercel link`.
AI_GATEWAY_API_KEY=

# Provider switch — set to "deepseek" to call the real Gateway, leave unset for
# the offline KB heuristic mock. Public so the client can branch UI.
NEXT_PUBLIC_AI_PROVIDER=mock

# Provisioned automatically by Vercel Marketplace → Neon Postgres
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

