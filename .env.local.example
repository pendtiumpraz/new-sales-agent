# Deepseek API key — get one at https://platform.deepseek.com → API Keys.
# Used directly (no Vercel AI Gateway). Server-side only — never exposed
# to the browser.
DEEPSEEK_API_KEY=

# Provider switch — set to "deepseek" to call the real Deepseek API, leave
# unset (or set to "mock") for the offline KB heuristic mock. Public so the
# client can branch UI.
NEXT_PUBLIC_AI_PROVIDER=mock

# Provisioned automatically by Vercel Marketplace → Neon Postgres
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# --- WhatsApp ---------------------------------------------------------------
# Shared secret that authenticates gateway/extension/WAHA-webhook calls.
WA_GATEWAY_TOKEN=
# Auto-reply to inbound WA with the AI orchestrator (1 = on).
WA_AUTO_REPLY=0

# WAHA (hosted, https://waha.devlike.pro) — set these and the app drives WAHA
# directly: one session per account (1 account = 1 QR), replies sent via WAHA.
# Leave unset to use the VPS-gateway/extension outbox model instead.
# WAHA_URL is accepted as an alias for WAHA_BASE_URL.
WAHA_BASE_URL=
WAHA_API_KEY=
WAHA_SESSION=default
# Public base WAHA calls back for inbound webhooks (your Vercel deploy URL).
# Locally, the app uses the request origin if this is unset.
APP_URL=

# Per-rep ingest token tenant fallback (Chrome-extension discovery → /api/ingest).
LINKEDIN_INGEST_TOKEN=
LINKEDIN_INGEST_TENANT=t_default
