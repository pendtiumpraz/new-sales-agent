{
  "manifest_version": 3,
  "name": "Maira Sales — Multi-Platform Lead Collector",
  "version": "0.12.1",
  "description": "Collect + enrich leads from LinkedIn, Google, Tokopedia, Shopee, Instagram, TikTok + DuckDuckGo internet search — RPA + AI run in YOUR browser, buffered locally, sent to the platform. Rate-limited, consent-gated.",
  "permissions": ["storage", "tabs", "scripting", "alarms", "downloads"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.google.com/*",
    "https://html.duckduckgo.com/*",
    "https://duckduckgo.com/*",
    "https://www.tokopedia.com/*",
    "https://shopee.co.id/*",
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "https://api.deepseek.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Maira Sales Collector"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/search/*", "https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.tokopedia.com/*",
        "https://shopee.co.id/*",
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*"
      ],
      "js": ["platforms.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*", "https://*/*"],
      "js": ["detect.js"],
      "run_at": "document_idle"
    }
  ]
}
