{
  "manifest_version": 3,
  "name": "Maira Sales — LinkedIn Lead Collector",
  "version": "0.2.0",
  "description": "Collect + enrich LinkedIn leads into your Maira Sales workspace — runs in YOUR logged-in session (RPA), rate-limited, consent-gated. No credentials stored.",
  "permissions": ["storage", "tabs", "scripting", "alarms"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Maira Sales Collector"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/search/*", "https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
