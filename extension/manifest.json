{
  "manifest_version": 3,
  "name": "Maira Sales — LinkedIn Lead Collector",
  "version": "0.6.0",
  "description": "Collect + enrich leads into your Maira Sales workspace — RPA scrape + DeepSeek AI websearch run in YOUR browser, buffered locally, then sent to the platform. Rate-limited, consent-gated.",
  "permissions": ["storage", "tabs", "scripting", "alarms"],
  "host_permissions": ["https://www.linkedin.com/*", "https://api.deepseek.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Maira Sales Collector"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/search/*", "https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*", "https://*/*"],
      "js": ["detect.js"],
      "run_at": "document_idle"
    }
  ]
}
